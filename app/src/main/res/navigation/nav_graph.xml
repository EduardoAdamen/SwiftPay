<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- Auth -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.swiftpay.ui.auth.LoginFragment"
        android:label="@string/login_title" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.swiftpay.ui.auth.ProfileFragment"
        android:label="@string/menu_profile" />

    <fragment
        android:id="@+id/changePasswordFragment"
        android:name="com.swiftpay.ui.auth.ChangePasswordFragment"
        android:label="@string/change_password_title" />

    <fragment
        android:id="@+id/forcePasswordChangeFragment"
        android:name="com.swiftpay.ui.auth.ForcePasswordChangeFragment"
        android:label="@string/force_change_password_title" />

    <fragment
        android:id="@+id/userManagementFragment"
        android:name="com.swiftpay.ui.auth.UserManagementFragment"
        android:label="@string/menu_users">
        <action
            android:id="@+id/action_userManagement_to_userForm"
            app:destination="@id/userFormFragment" />
    </fragment>

    <fragment
        android:id="@+id/userFormFragment"
        android:name="com.swiftpay.ui.auth.UserFormFragment"
        android:label="Crear Usuario" />

    <!-- Common -->
    <fragment
        android:id="@+id/accessDeniedFragment"
        android:name="com.swiftpay.ui.common.AccessDeniedFragment"
        android:label="@string/access_denied" />

    <!-- Placeholder Dashboard para permitir navegaciĂłn inicial -->
    <fragment
        android:id="@+id/nav_dashboard"
        android:name="com.swiftpay.ui.dashboard.DashboardFragment"
        android:label="@string/menu_dashboard">
        <action android:id="@+id/action_dashboard_to_eventList" app:destination="@id/eventListFragment" />
    </fragment>
    
    <fragment
        android:id="@+id/eventListFragment"
        android:name="com.swiftpay.ui.dashboard.EventListFragment"
        android:label="Eventos del Sistema" />

    <!-- CatĂˇlogo de Productos y Marcas -->
    <fragment
        android:id="@+id/productListFragment"
        android:name="com.swiftpay.ui.catalog.ProductListFragment"
        android:label="@string/menu_products">
        <action
            android:id="@+id/action_productList_to_productForm"
            app:destination="@id/productFormFragment" />
        <action
            android:id="@+id/action_productList_to_productDetail"
            app:destination="@id/productDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/brandListFragment"
        android:name="com.swiftpay.ui.catalog.BrandListFragment"
        android:label="@string/menu_brands">
        <action
            android:id="@+id/action_brandList_to_brandForm"
            app:destination="@id/brandFormFragment" />
    </fragment>

    <fragment
        android:id="@+id/barcodeScannerFragment"
        android:name="com.swiftpay.ui.catalog.BarcodeScannerFragment"
        android:label="EscĂˇner" />

    <!-- Clientes y Descuentos -->
    <fragment
        android:id="@+id/clientListFragment"
        android:name="com.swiftpay.ui.clientes.ClientListFragment"
        android:label="@string/menu_clients">
        <action
            android:id="@+id/action_clientList_to_clientForm"
            app:destination="@id/clientFormFragment" />
        <action
            android:id="@+id/action_clientList_to_clientDetail"
            app:destination="@id/clientDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/discountListFragment"
        android:name="com.swiftpay.ui.descuentos.DiscountListFragment"
        android:label="@string/menu_discounts">
        <action
            android:id="@+id/action_discountList_to_discountForm"
            app:destination="@id/discountFormFragment" />
    </fragment>

    <!-- Ventas -->
    <fragment
        android:id="@+id/saleListFragment"
        android:name="com.swiftpay.ui.ventas.SaleListFragment"
        android:label="Historial de Ventas" />

    <fragment
        android:id="@+id/saleCartFragment"
        android:name="com.swiftpay.ui.ventas.SaleCartFragment"
        android:label="Nueva Venta" />

    <fragment
        android:id="@+id/salePaymentFragment"
        android:name="com.swiftpay.ui.ventas.SalePaymentFragment"
        android:label="Pago" />

    <fragment
        android:id="@+id/saleDetailFragment"
        android:name="com.swiftpay.ui.ventas.SaleDetailFragment"
        android:label="Detalle de Venta" />

    <fragment
        android:id="@+id/cashOpenFragment"
        android:name="com.swiftpay.ui.ventas.CashOpenFragment"
        android:label="Apertura de Caja" />

    <fragment
        android:id="@+id/cashCloseFragment"
        android:name="com.swiftpay.ui.ventas.CashCloseFragment"
        android:label="Cierre de Caja" />

    <fragment
        android:id="@+id/cashReportFragment"
        android:name="com.swiftpay.ui.ventas.CashReportFragment"
        android:label="Reporte de Arqueo" />

    <fragment
        android:id="@+id/saleStatusHistoryFragment"
        android:name="com.swiftpay.ui.ventas.SaleStatusHistoryFragment"
        android:label="Historial de Estados" />

    <!-- Mapeo de IDs de menĂş a destinos futuros (Sprints 5+) -->
    <!-- MĂłdulos Sprint 6 Proveedores y Ordenes -->
    <fragment
        android:id="@+id/nav_suppliers"
        android:name="com.swiftpay.ui.proveedores.SupplierListFragment"
        android:label="Proveedores">
        <action
            android:id="@+id/action_supplierList_to_supplierDetail"
            app:destination="@id/supplierDetailFragment" />
        <action
            android:id="@+id/action_supplierList_to_supplierForm"
            app:destination="@id/supplierFormFragment" />
    </fragment>

    <fragment
        android:id="@+id/supplierDetailFragment"
        android:name="com.swiftpay.ui.proveedores.SupplierDetailFragment"
        android:label="Detalle Proveedor">
        <action
            android:id="@+id/action_supplierDetail_to_supplierForm"
            app:destination="@id/supplierFormFragment" />
    </fragment>

    <fragment
        android:id="@+id/supplierFormFragment"
        android:name="com.swiftpay.ui.proveedores.SupplierFormFragment"
        android:label="Proveedor" />

    <fragment
        android:id="@+id/nav_purchase_orders"
        android:name="com.swiftpay.ui.proveedores.PurchaseOrderListFragment"
        android:label="Ă“rdenes de Compra">
        <action
            android:id="@+id/action_purchaseOrderList_to_purchaseOrderDetail"
            app:destination="@id/purchaseOrderDetailFragment" />
        <action
            android:id="@+id/action_purchaseOrderList_to_purchaseOrderForm"
            app:destination="@id/purchaseOrderFormFragment" />
    </fragment>

    <fragment
        android:id="@+id/purchaseOrderDetailFragment"
        android:name="com.swiftpay.ui.proveedores.PurchaseOrderDetailFragment"
        android:label="Detalle Orden">
        <action
            android:id="@+id/action_purchaseOrderDetail_to_purchaseOrderForm"
            app:destination="@id/purchaseOrderFormFragment" />
        <action
            android:id="@+id/action_purchaseOrderDetail_to_purchaseOrderReceive"
            app:destination="@id/purchaseOrderReceiveFragment" />
    </fragment>

    <fragment
        android:id="@+id/purchaseOrderFormFragment"
        android:name="com.swiftpay.ui.proveedores.PurchaseOrderFormFragment"
        android:label="Orden de Compra" />

    <fragment
        android:id="@+id/purchaseOrderReceiveFragment"
        android:name="com.swiftpay.ui.proveedores.PurchaseOrderReceiveFragment"
        android:label="RecepciĂłn MercancĂ­a" />

    <!-- Destinos de CatĂˇlogo -->
    <fragment
        android:id="@+id/productFormFragment"
        android:name="com.swiftpay.ui.catalog.ProductFormFragment"
        android:label="Crear/Editar Producto" />

    <fragment
        android:id="@+id/productDetailFragment"
        android:name="com.swiftpay.ui.catalog.ProductDetailFragment"
        android:label="Detalles de Producto" />

    <fragment
        android:id="@+id/brandFormFragment"
        android:name="com.swiftpay.ui.catalog.BrandFormFragment"
        android:label="Crear/Editar Marca" />
        
    <!-- Destinos de Clientes -->
    <fragment
        android:id="@+id/clientFormFragment"
        android:name="com.swiftpay.ui.clientes.ClientFormFragment"
        android:label="Crear/Editar Cliente" />

    <fragment
        android:id="@+id/clientDetailFragment"
        android:name="com.swiftpay.ui.clientes.ClientDetailFragment"
        android:label="Detalles de Cliente" />

    <!-- Destinos de Descuentos -->
    <fragment
        android:id="@+id/discountFormFragment"
        android:name="com.swiftpay.ui.descuentos.DiscountFormFragment"
        android:label="Crear/Editar Descuento" />

    <action android:id="@+id/action_global_nav_profile" app:destination="@id/profileFragment" />
    <action android:id="@+id/action_global_nav_users" app:destination="@id/userManagementFragment" />
    <action android:id="@+id/action_global_nav_products" app:destination="@id/productListFragment" />
    <action android:id="@+id/action_global_nav_brands" app:destination="@id/brandListFragment" />
    <action android:id="@+id/action_global_nav_clients" app:destination="@id/clientListFragment" />
    <action android:id="@+id/action_global_nav_discounts" app:destination="@id/discountListFragment" />
    <action android:id="@+id/action_global_nav_sales" app:destination="@id/saleListFragment" />

    <fragment android:id="@+id/settingsFragment" android:name="com.swiftpay.ui.settings.SettingsFragment" android:label="Configuración" />`n</navigation>



