<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/nav_header_height"
    android:orientation="vertical"
    android:gravity="bottom"
    android:paddingStart="@dimen/spacing_sections"
    android:paddingEnd="@dimen/spacing_sections"
    android:paddingBottom="@dimen/spacing_sections"
    android:paddingTop="48dp"
    android:background="@color/colorPrimary">

    <!-- Avatar con borde circular -->
    <FrameLayout
        android:layout_width="@dimen/avatar_large"
        android:layout_height="@dimen/avatar_large"
        android:layout_marginBottom="@dimen/spacing_elements_lg">

        <ImageView
            android:id="@+id/iv_nav_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_account_circle"
            android:contentDescription="@string/menu_profile"
            android:background="@drawable/bg_avatar_ring" />
    </FrameLayout>

    <!-- Nombre del usuario -->
    <TextView
        android:id="@+id/tv_nav_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/nav_header_default_name"
        android:textAppearance="@style/TextAppearance.SwiftPay.TitleLarge"
        android:textColor="@color/colorOnPrimary"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <!-- Rol del usuario como chip/badge -->
    <TextView
        android:id="@+id/tv_nav_role"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/nav_header_default_role"
        android:textAppearance="@style/TextAppearance.SwiftPay.LabelMedium"
        android:textColor="@color/colorOnPrimary"
        android:alpha="0.75"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        android:background="@drawable/bg_role_badge" />

</LinearLayout>
