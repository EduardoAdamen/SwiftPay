<?xml version="1.0" encoding="utf-8"?>
<!-- app/src/main/res/layout/view_loading_state.xml -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/loadingStateRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- Loading state -->
    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_lateral"
            android:text="@string/loading_state_loading"
            android:textAppearance="@style/TextAppearance.SwiftPay.BodyMedium"
            android:textColor="@color/colorTextSecondary" />
    </LinearLayout>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="@dimen/avatar_large"
            android:layout_height="@dimen/avatar_large"
            android:src="@drawable/ic_inventory"
            android:contentDescription="@string/no_data"
            android:alpha="0.4" />

        <TextView
            android:id="@+id/tvEmptyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_lateral"
            android:text="@string/loading_state_empty"
            android:textAppearance="@style/TextAppearance.SwiftPay.BodyLarge"
            android:textColor="@color/colorTextSecondary" />
    </LinearLayout>

    <!-- Error state -->
    <LinearLayout
        android:id="@+id/layoutError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="@dimen/avatar_large"
            android:layout_height="@dimen/avatar_large"
            android:src="@drawable/ic_error"
            android:contentDescription="@string/error_generic"
            android:alpha="0.4" />

        <TextView
            android:id="@+id/tvErrorMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_lateral"
            android:text="@string/loading_state_error"
            android:textAppearance="@style/TextAppearance.SwiftPay.BodyLarge"
            android:textColor="@color/colorError" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            style="@style/Widget.SwiftPay.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_lateral"
            android:text="@string/btn_retry" />
    </LinearLayout>

</FrameLayout>
