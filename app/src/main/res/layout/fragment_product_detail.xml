<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Imagen del producto -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:background="@color/colorSurfaceVariant">
            
            <ImageView
                android:id="@+id/iv_product_detail_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_inventory_2"
                android:contentDescription="Product Image" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_lateral">

            <TextView
                android:id="@+id/tv_detail_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineMedium"
                android:textColor="@color/colorTextPrimary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_detail_sku"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.SwiftPay.BodyMedium"
                android:textColor="@color/colorTextSecondary"
                android:layout_marginBottom="@dimen/spacing_sections" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sections" />

            <!-- Precio y Stock -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_sections">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Precio"
                        android:textAppearance="@style/TextAppearance.SwiftPay.LabelLarge"
                        android:textColor="@color/colorTextSecondary" />
                        
                    <TextView
                        android:id="@+id/tv_detail_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineSmall"
                        android:textColor="@color/colorPrimary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stock Disponible"
                        android:textAppearance="@style/TextAppearance.SwiftPay.LabelLarge"
                        android:textColor="@color/colorTextSecondary" />
                        
                    <TextView
                        android:id="@+id/tv_detail_stock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineSmall"
                        android:textColor="@color/colorTextPrimary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Marca -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/spacing_sections">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Marca"
                    android:textAppearance="@style/TextAppearance.SwiftPay.LabelLarge"
                    android:textColor="@color/colorTextSecondary" />

                <TextView
                    android:id="@+id/tv_detail_brand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sin marca"
                    android:textAppearance="@style/TextAppearance.SwiftPay.BodyLarge"
                    android:textColor="@color/colorTextPrimary" />
            </LinearLayout>

            <!-- Proveedor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/spacing_sections">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Proveedor"
                    android:textAppearance="@style/TextAppearance.SwiftPay.LabelLarge"
                    android:textColor="@color/colorTextSecondary" />

                <TextView
                    android:id="@+id/tv_detail_supplier"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sin proveedor"
                    android:textAppearance="@style/TextAppearance.SwiftPay.BodyLarge"
                    android:textColor="@color/colorTextPrimary" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción"
                android:textAppearance="@style/TextAppearance.SwiftPay.LabelLarge"
                android:textColor="@color/colorTextSecondary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_detail_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.SwiftPay.BodyLarge"
                android:textColor="@color/colorTextPrimary"
                android:layout_marginBottom="@dimen/spacing_sections" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_product"
                style="@style/Widget.SwiftPay.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/btn_edit"
                app:icon="@drawable/ic_edit"
                android:layout_marginBottom="@dimen/spacing_elements" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_product"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/btn_delete"
                android:textColor="@color/colorError"
                app:iconTint="@color/colorError"
                app:strokeColor="@color/colorError"
                app:icon="@drawable/ic_delete" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
