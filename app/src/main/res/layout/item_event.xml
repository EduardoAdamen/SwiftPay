<?xml version="1.0" encoding="utf-8"?>
<!-- app/src/main/res/layout/item_event.xml -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_elements"
    style="@style/Widget.SwiftPay.CardView">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin_lateral">

        <TextView
            android:id="@+id/tvEventType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.SwiftPay.LabelLarge"
            android:textColor="?attr/colorPrimary"/>

        <TextView
            android:id="@+id/tvEventDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.SwiftPay.BodyLarge"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="@dimen/spacing_elements"/>

        <TextView
            android:id="@+id/tvEventDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.SwiftPay.BodyMedium"
            android:textColor="@color/colorTextSecondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMarkReviewed"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:minHeight="@dimen/button_height"
            android:text="@string/events_mark_reviewed" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>