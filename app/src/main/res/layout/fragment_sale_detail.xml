<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Section -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/bg_hero_gradient">
                
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_avatar_ring"
                    android:layout_marginBottom="20dp">
                    
                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_payments"
                        app:tint="@color/white"
                        android:contentDescription="Venta" />
                </FrameLayout>
            </FrameLayout>

            <!-- Main Content Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-40dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="32dp"
                android:layout_marginHorizontal="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="32dp"
                    android:paddingBottom="40dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:id="@+id/tv_detail_id"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineSmall"
                            android:textColor="@color/colorTextPrimary"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/chip_detail_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:textAppearance="@style/TextAppearance.SwiftPay.LabelMedium"
                            android:textColor="@color/white"
                            android:background="@drawable/bg_status_badge" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_detail_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.SwiftPay.LabelMedium"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_detail_payment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.SwiftPay.LabelMedium"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="24dp" />

                    <!-- Articulos -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Artículos de la Venta"
                        android:textAppearance="@style/TextAppearance.SwiftPay.LabelSection"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="8dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_sale_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:layout_marginBottom="24dp" />

                    <!-- Totals Block -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_role_badge"
                        android:padding="16dp"
                        android:layout_marginBottom="24dp">
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Subtotal:"
                                android:textAppearance="@style/TextAppearance.SwiftPay.BodyMedium"
                                android:textColor="@color/colorTextSecondary" />
                            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
                            <TextView
                                android:id="@+id/tv_detail_subtotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/colorTextPrimary"
                                android:textAppearance="@style/TextAppearance.SwiftPay.BodyMedium" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/ll_discount_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Descuento:"
                                android:textAppearance="@style/TextAppearance.SwiftPay.BodyMedium"
                                android:textColor="@color/colorTextSecondary" />
                            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
                            <TextView
                                android:id="@+id/tv_detail_discount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/colorError"
                                android:textAppearance="@style/TextAppearance.SwiftPay.BodyMedium" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/colorDivider"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total:"
                                android:textStyle="bold"
                                android:textAppearance="@style/TextAppearance.SwiftPay.TitleLarge" />
                            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
                            <TextView
                                android:id="@+id/tv_detail_total"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textStyle="bold"
                                android:textColor="@color/colorPrimary"
                                android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineMedium" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Acciones de Impresion -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="24dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_generate_pdf"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            app:icon="@drawable/ic_description"
                            android:text="PDF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_print_bluetooth"
                            style="@style/Widget.SwiftPay.Button.Primary"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1.5"
                            android:layout_marginStart="4dp"
                            android:text="Imprimir Ticket"
                            app:icon="@drawable/ic_print" />
                    </LinearLayout>

                    <!-- Acciones de Venta -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_cancel_sale"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/colorError"
                            android:text="Cancelar Venta" />

                        <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_complete_sale"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/colorPrimary"
                            android:text="Marcar Completada" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
