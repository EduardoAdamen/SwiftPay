<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header / Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/spacing_elements"
            android:background="@color/colorSurface"
            android:elevation="@dimen/elevation_card">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_scan_product"
                style="@style/Widget.SwiftPay.Button.Tonal"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_point_of_sale"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:padding="0dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_elements"
                android:hint="Buscar Producto"
                app:startIconDrawable="@drawable/ic_search"
                app:boxCornerRadiusTopStart="28dp"
                app:boxCornerRadiusBottomStart="28dp"
                app:boxCornerRadiusTopEnd="28dp"
                app:boxCornerRadiusBottomEnd="28dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_search_product"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Dynamic Content Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/margin_lateral"
                android:paddingTop="@dimen/spacing_elements_lg"
                android:paddingBottom="4dp"
                android:text="@string/sale_cart_catalog_title"
                android:textAppearance="@style/TextAppearance.SwiftPay.LabelSection"
                android:textColor="@color/colorTextSecondary" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_catalog_products"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingVertical="4dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/margin_lateral"
                android:paddingTop="@dimen/spacing_elements"
                android:paddingBottom="4dp"
                android:text="@string/sale_cart_items_title"
                android:textAppearance="@style/TextAppearance.SwiftPay.LabelSection"
                android:textColor="@color/colorTextSecondary" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_cart_items"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1.5"
                android:paddingVertical="4dp"
                android:clipToPadding="false" />
        </LinearLayout>

        <!-- Premium Checkout Bottom Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="0dp"
            app:cardCornerRadius="24dp"
            android:layout_marginHorizontal="-8dp"
            android:layout_marginBottom="-8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <!-- Client Selection -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_role_badge"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:layout_marginBottom="8dp">
                    
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_people"
                        app:tint="@color/colorPrimary"
                        android:layout_marginEnd="8dp" />
                        
                    <TextView
                        android:id="@+id/tv_cart_client"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Público General"
                        android:textAppearance="@style/TextAppearance.SwiftPay.LabelMedium"
                        android:textColor="@color/colorTextPrimary" />
                        
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_assign_client"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cambiar"
                        android:textColor="@color/colorPrimary"
                        android:textSize="12sp"
                        android:minHeight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp" />
                </LinearLayout>

                <!-- Subtotal Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="0dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Subtotal"
                        android:textAppearance="@style/TextAppearance.SwiftPay.BodyMedium"
                        android:textColor="@color/colorTextSecondary" />
                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                    <TextView
                        android:id="@+id/tv_cart_subtotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0.00"
                        android:textAppearance="@style/TextAppearance.SwiftPay.TitleMedium"
                        android:textColor="@color/colorTextPrimary" />
                </LinearLayout>

                <!-- Discount Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_add_discount"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sale_cart_apply_discount"
                        android:textColor="@color/colorWarning"
                        android:textSize="14sp"
                        android:minHeight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp" />
                        
                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                        
                    <TextView
                        android:id="@+id/tv_cart_discount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-$0.00"
                        android:textColor="@color/colorWarning"
                        android:textAppearance="@style/TextAppearance.SwiftPay.TitleMedium" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorDivider"
                    android:layout_marginVertical="8dp" />

                <!-- Total Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total"
                        android:textStyle="bold"
                        android:textAppearance="@style/TextAppearance.SwiftPay.TitleLarge" />
                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                    <TextView
                        android:id="@+id/tv_cart_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0.00"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineMedium" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_checkout"
                    style="@style/Widget.SwiftPay.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Cobrar"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_payments"
                    app:iconGravity="textStart" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
