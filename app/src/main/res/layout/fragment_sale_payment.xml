<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/margin_lateral"
    android:background="@color/colorBackground">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total a Cobrar"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.SwiftPay.TitleMedium"
        android:textColor="@color/colorTextSecondary" />

    <TextView
        android:id="@+id/tv_payment_total"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="$0.00"
        android:gravity="center"
        android:textStyle="bold"
        android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineLarge"
        android:textColor="@color/colorPrimary"
        android:layout_marginBottom="@dimen/spacing_sections" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Método de Pago"
        android:textAppearance="@style/TextAppearance.SwiftPay.LabelLarge"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rg_payment_method"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/spacing_sections">

        <RadioButton
            android:id="@+id/rb_cash"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Efectivo"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rb_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tarjeta" />

        <RadioButton
            android:id="@+id/rb_transfer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Transfer." />
    </RadioGroup>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_amount_received"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_sections"
        android:hint="Monto Recibido ($)">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_amount_received"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/spacing_sections">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cambio:"
            android:textAppearance="@style/TextAppearance.SwiftPay.TitleMedium" />
        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />
        <TextView
            android:id="@+id/tv_payment_change"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0.00"
            android:textStyle="bold"
            android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineMedium"
            android:textColor="@color/colorSuccess" />
    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_confirm_payment"
        style="@style/Widget.SwiftPay.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="Confirmar Venta" />

</LinearLayout>
