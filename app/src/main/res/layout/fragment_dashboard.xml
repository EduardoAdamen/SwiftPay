<?xml version="1.0" encoding="utf-8"?>
<!-- Modern Dashboard with stats grid and KPI cards -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin_lateral"
        android:paddingBottom="@dimen/spacing_sections_lg">



        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dashboard_overview"
            android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineMedium"
            android:textColor="@color/colorTextPrimary"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/spacing_sections" />

        <!-- KPI Row 1: Ventas y Clientes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="@dimen/spacing_elements_lg">

            <!-- Ventas hoy -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="140dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="@dimen/corner_radius_card_lg"
            app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="@dimen/icon_stat"
                        android:layout_height="@dimen/icon_stat"
                        android:src="@drawable/ic_point_of_sale"
                        android:padding="8dp"
                        android:background="@drawable/bg_icon_stat_primary"
                        app:tint="@color/colorPrimary"
                        android:contentDescription="Ventas"
                        android:layout_marginBottom="@dimen/spacing_elements" />

                    <TextView
                        android:id="@+id/tvNewSalesCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineMedium"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_new_sales"
                        android:textAppearance="@style/TextAppearance.SwiftPay.LabelMedium"
                        android:textColor="@color/colorTextSecondary" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Clientes nuevos -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="140dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="@dimen/corner_radius_card_lg"
            app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="@dimen/icon_stat"
                        android:layout_height="@dimen/icon_stat"
                        android:src="@drawable/ic_people"
                        android:padding="8dp"
                        android:background="@drawable/bg_icon_stat_success"
                        app:tint="@color/colorSuccess"
                        android:contentDescription="Clientes"
                        android:layout_marginBottom="@dimen/spacing_elements" />

                    <TextView
                        android:id="@+id/tvNewClientsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineMedium"
                        android:textStyle="bold"
                        android:textColor="@color/colorSuccess" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_new_clients"
                        android:textAppearance="@style/TextAppearance.SwiftPay.LabelMedium"
                        android:textColor="@color/colorTextSecondary" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Divider section label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Actividad"
            android:textAppearance="@style/TextAppearance.SwiftPay.LabelSection"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="@dimen/spacing_elements_lg"
            android:layout_marginBottom="@dimen/spacing_elements" />

        <!-- Events button card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvViewEvents"
            app:cardCornerRadius="@dimen/corner_radius_card_lg"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:layout_marginBottom="@dimen/spacing_elements_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/padding_card"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_history"
                    android:padding="8dp"
                    android:background="@drawable/bg_icon_stat_info"
                    app:tint="@color/colorInfo"
                    android:contentDescription="Eventos"
                    android:layout_marginEnd="@dimen/spacing_elements_lg" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Eventos del sistema"
                        android:textAppearance="@style/TextAppearance.SwiftPay.TitleMedium"
                        android:textColor="@color/colorTextPrimary" />

                    <TextView
                        android:id="@+id/tvEventsSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ver todas las actividades registradas"
                        android:textAppearance="@style/TextAppearance.SwiftPay.LabelMedium"
                        android:textColor="@color/colorTextSecondary" />
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="180"
                    app:tint="@color/colorTextSecondary"
                    android:contentDescription="Ver más" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
