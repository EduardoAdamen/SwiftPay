<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¿Confirmar recepción de mercancía?"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="El stock de los productos asociados será incrementado de forma atómica y el estado de la orden pasará a RECIBIDA."
        android:textSize="16sp"
        android:gravity="center" />

    <Button
        android:id="@+id/btn_confirm_receive"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Confirmar y Actualizar Stock"
        android:backgroundTint="@android:color/holo_green_dark" />

</LinearLayout>
