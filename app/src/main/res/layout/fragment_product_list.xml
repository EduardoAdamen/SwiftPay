<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Barra de búsqueda y escáner -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_elements"
            app:cardCornerRadius="@dimen/corner_radius_card"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/spacing_elements">

                <ImageView
                    android:layout_width="@dimen/icon_action"
                    android:layout_height="@dimen/icon_action"
                    android:src="@drawable/ic_search"
                    app:tint="@color/colorTextSecondary"
                    android:contentDescription="@string/btn_search" />

                <EditText
                    android:id="@+id/et_search_product"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Buscar producto o SKU..."
                    android:inputType="text"
                    android:maxLines="1"
                    android:paddingHorizontal="@dimen/spacing_elements"
                    android:textAppearance="@style/TextAppearance.SwiftPay.BodyLarge" />

                <ImageButton
                    android:id="@+id/btn_scan_barcode"
                    android:layout_width="@dimen/icon_action"
                    android:layout_height="@dimen/icon_action"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_branding_watermark"
                    app:tint="@color/colorPrimary"
                    android:contentDescription="Escanear" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_products"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_products"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingVertical="@dimen/spacing_elements" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_product"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/margin_lateral"
        android:contentDescription="@string/btn_create"
        app:srcCompat="@drawable/ic_add"
        app:tint="@color/white"
        app:backgroundTint="@color/colorPrimary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
