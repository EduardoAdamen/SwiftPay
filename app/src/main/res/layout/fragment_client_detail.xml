<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin_lateral">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_people"
            app:tint="@color/colorPrimary"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/spacing_elements"
            android:contentDescription="Avatar" />

        <TextView
            android:id="@+id/tv_detail_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineMedium"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_detail_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textAppearance="@style/TextAppearance.SwiftPay.BodyMedium"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="@dimen/spacing_sections" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_sections" />

        <!-- Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_sections">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Compras Totales"
                    android:textAppearance="@style/TextAppearance.SwiftPay.LabelLarge"
                    android:textColor="@color/colorTextSecondary" />
                    
                <TextView
                    android:id="@+id/tv_detail_purchases"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineSmall"
                    android:textColor="@color/colorPrimary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gastado"
                    android:textAppearance="@style/TextAppearance.SwiftPay.LabelLarge"
                    android:textColor="@color/colorTextSecondary" />
                    
                <TextView
                    android:id="@+id/tv_detail_spent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineSmall"
                    android:textColor="@color/colorTextPrimary" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_edit_client"
            style="@style/Widget.SwiftPay.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/btn_edit"
            app:icon="@drawable/ic_edit"
            android:layout_marginBottom="@dimen/spacing_elements" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete_client"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="Desactivar / Eliminar"
            android:textColor="@color/colorError"
            app:iconTint="@color/colorError"
            app:strokeColor="@color/colorError"
            app:icon="@drawable/ic_delete" />

    </LinearLayout>
</ScrollView>
