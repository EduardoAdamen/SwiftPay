<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Section -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/bg_hero_gradient">
                
                <!-- Avatar Container -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_avatar_ring"
                    android:layout_marginBottom="20dp">
                    
                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_people"
                        app:tint="@color/white"
                        android:contentDescription="Avatar" />
                </FrameLayout>
            </FrameLayout>

            <!-- Main Content Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-40dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="32dp"
                android:layout_marginHorizontal="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="32dp"
                    android:paddingBottom="40dp">

                    <TextView
                        android:id="@+id/tv_detail_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineMedium"
                        android:textColor="@color/colorTextPrimary"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_detail_category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Categoría"
                        android:textAppearance="@style/TextAppearance.SwiftPay.LabelMedium"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="32dp" />

                    <!-- Stats Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_role_badge"
                        android:padding="16dp"
                        android:layout_marginBottom="32dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Compras"
                                android:textAppearance="@style/TextAppearance.SwiftPay.LabelSmall"
                                android:textColor="@color/colorTextSecondary"
                                android:textAllCaps="true" />
                                
                            <TextView
                                android:id="@+id/tv_detail_purchases"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.SwiftPay.TitleLarge"
                                android:textColor="@color/colorPrimary"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/colorDivider"
                            android:layout_marginHorizontal="16dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Gastado"
                                android:textAppearance="@style/TextAppearance.SwiftPay.LabelSmall"
                                android:textColor="@color/colorTextSecondary"
                                android:textAllCaps="true" />
                                
                            <TextView
                                android:id="@+id/tv_detail_spent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.SwiftPay.TitleLarge"
                                android:textColor="@color/colorTextPrimary"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Actions -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_edit_client"
                            style="@style/Widget.SwiftPay.Button.Primary"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="@string/btn_edit"
                            app:icon="@drawable/ic_edit"
                            android:layout_marginBottom="12dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_delete_client"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="Desactivar / Eliminar"
                            android:textColor="@color/colorError"
                            app:iconTint="@color/colorError"
                            app:strokeColor="@color/colorError"
                            app:icon="@drawable/ic_delete" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
