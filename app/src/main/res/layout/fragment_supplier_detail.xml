<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Section -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@color/colorPrimary">
                
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_logo_circle"
                    android:layout_marginBottom="20dp">
                    
                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_business"
                        app:tint="@color/colorPrimary"
                        android:contentDescription="Proveedor" />
                </FrameLayout>
            </FrameLayout>

            <!-- Main Content Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-40dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="32dp"
                android:layout_marginHorizontal="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="32dp"
                    android:paddingBottom="40dp">

                    <TextView
                        android:id="@+id/tv_detail_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineMedium"
                        android:textColor="@color/colorTextPrimary"
                        android:textStyle="bold"
                        android:layout_marginBottom="32dp" />

                    <!-- Contact Details -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Información de Contacto"
                        android:textAppearance="@style/TextAppearance.SwiftPay.LabelSection"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_receipt"
                            app:tint="@color/colorTextSecondary"
                            android:layout_marginEnd="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RFC"
                                android:textAppearance="@style/TextAppearance.SwiftPay.LabelSmall"
                                android:textColor="@color/colorTextSecondary" />
                            <TextView
                                android:id="@+id/tv_detail_rfc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.SwiftPay.BodyLarge"
                                android:textColor="@color/colorTextPrimary" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_phone"
                            app:tint="@color/colorTextSecondary"
                            android:layout_marginEnd="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Teléfono"
                                android:textAppearance="@style/TextAppearance.SwiftPay.LabelSmall"
                                android:textColor="@color/colorTextSecondary" />
                            <TextView
                                android:id="@+id/tv_detail_phone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.SwiftPay.BodyLarge"
                                android:textColor="@color/colorTextPrimary" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="32dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_email"
                            app:tint="@color/colorTextSecondary"
                            android:layout_marginEnd="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Correo Electrónico"
                                android:textAppearance="@style/TextAppearance.SwiftPay.LabelSmall"
                                android:textColor="@color/colorTextSecondary" />
                            <TextView
                                android:id="@+id/tv_detail_email"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.SwiftPay.BodyLarge"
                                android:textColor="@color/colorTextPrimary" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notas Adicionales"
                        android:textAppearance="@style/TextAppearance.SwiftPay.LabelSection"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_detail_notes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.SwiftPay.BodyLarge"
                        android:textColor="@color/colorTextPrimary"
                        android:background="@drawable/bg_role_badge"
                        android:padding="16dp"
                        android:layout_marginBottom="32dp" />

                    <!-- Actions -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_edit_supplier"
                        style="@style/Widget.SwiftPay.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Editar Proveedor"
                        app:icon="@drawable/ic_edit" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
