<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/margin_lateral">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="@dimen/spacing_sections"
            android:src="@drawable/ic_lock"
            android:contentDescription="@string/force_change_password_title"
            app:tint="@color/colorWarning" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/force_change_password_title"
            android:textAppearance="@style/TextAppearance.SwiftPay.HeadlineSmall"
            android:textColor="@color/colorTextPrimary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_elements" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/force_change_password_message"
            android:textAppearance="@style/TextAppearance.SwiftPay.BodyMedium"
            android:textColor="@color/colorTextSecondary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_sections" />

        <!-- Nueva contraseña -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_new_password"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_elements"
            android:hint="@string/hint_new_password"
            app:endIconMode="password_toggle"
            app:helperText="@string/password_requirements"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_new_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Confirmar -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_confirm_password"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_sections"
            android:hint="@string/hint_confirm_password"
            app:endIconMode="password_toggle"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_confirm_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:maxLines="1"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_password"
            style="@style/Widget.SwiftPay.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/btn_save_password"
            android:textAllCaps="false" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progress_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/margin_lateral"
            android:visibility="gone"
            android:indeterminate="true" />

    </LinearLayout>
</ScrollView>
