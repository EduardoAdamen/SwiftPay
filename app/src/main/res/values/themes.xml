<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema claro Material3 -->
    <style name="Base.Theme.SwiftPay" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/colorTextOnDark</item>
        <item name="colorError">@color/colorError</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceVariant</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="colorOnSurfaceVariant">@color/colorOnBackground</item>

        <!-- Tipografía -->
        <item name="android:fontFamily">sans-serif</item>

        <!-- Bordes y divisores -->
        <item name="android:listDivider">@color/colorDivider</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.SwiftPay.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.SwiftPay.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.SwiftPay.LargeComponent</item>
    </style>

    <style name="Theme.SwiftPay" parent="Base.Theme.SwiftPay" />

    <style name="ThemeOverlay.SwiftPay" parent="" />

    <style name="ThemeOverlay.SwiftPay.Default">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
    </style>

    <style name="ThemeOverlay.SwiftPay.Emerald">
        <item name="colorPrimary">@color/colorEmeraldPrimary</item>
        <item name="colorSecondary">@color/colorEmeraldAccent</item>
        <item name="colorOnPrimary">@color/colorTextOnDark</item>
    </style>

    <style name="ThemeOverlay.SwiftPay.Purple">
        <item name="colorPrimary">@color/colorPurplePrimary</item>
        <item name="colorSecondary">@color/colorPurpleAccent</item>
        <item name="colorOnPrimary">@color/colorTextOnDark</item>
    </style>

    <style name="ThemeOverlay.SwiftPay.Coral">
        <item name="colorPrimary">@color/colorCoralPrimary</item>
        <item name="colorSecondary">@color/colorCoralAccent</item>
        <item name="colorOnPrimary">@color/colorTextOnDark</item>
    </style>

    <style name="ThemeOverlay.SwiftPay.Teal">
        <item name="colorPrimary">@color/colorTealPrimary</item>
        <item name="colorSecondary">@color/colorTealAccent</item>
        <item name="colorOnPrimary">@color/colorTextOnDark</item>
    </style>

    <!-- Shapes -->
    <style name="ShapeAppearance.SwiftPay.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">@dimen/corner_radius_card</item>
    </style>

    <style name="ShapeAppearance.SwiftPay.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">@dimen/corner_radius_card</item>
    </style>

    <style name="ShapeAppearance.SwiftPay.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">@dimen/corner_radius_dialog</item>
    </style>
</resources>
